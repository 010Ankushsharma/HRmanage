<%- include('partials/navigation') %>

<div class="dashboard-container">
  <div class="container-fluid py-5">
    <div class="row justify-content-center">
      <div class="col-md-6 text-center">
        <div class="error-page">
          <h1 class="display-1 text-danger"><i class="fas fa-exclamation-triangle"></i></h1>
          <h2 class="mb-3">500 - Server Error</h2>
          <p class="lead text-muted mb-4"><%= message || 'Something went wrong!' %></p>
          <a href="/dashboard" class="btn btn-primary">
            <i class="fas fa-home me-2"></i>Go Back to Dashboard
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
