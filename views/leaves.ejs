<%- include('partials/navigation') %>

<div class="dashboard-container">
  <div class="container-fluid py-4">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Leave Management</h5>
        <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#applyLeaveModal">
          <i class="fas fa-plus me-2"></i>New Leave Request
        </button>
      </div>
      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-hover">
            <thead>
              <tr>
                <th>Employee</th>
                <th>Leave Type</th>
                <th>Start Date</th>
                <th>End Date</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if(leaves.length > 0) { %>
                <% leaves.forEach(leave => { %>
                  <tr>
                    <td>
                      <div class="d-flex align-items-center">
                        <img src="https://ui-avatars.com/api/?name=<%= leave.employee.name %>&background=random" 
                             alt="<%= leave.employee.name %>" class="rounded-circle me-2" width="40" height="40">
                        <div>
                          <h6 class="mb-0"><%= leave.employee.name %></h6>
                          <small class="text-muted"><%= leave.employee.department %></small>
                        </div>
                      </div>
                    </td>
                    <td><%= leave.leaveType %></td>
                    <td><%= new Date(leave.startDate).toLocaleDateString() %></td>
                    <td><%= new Date(leave.endDate).toLocaleDateString() %></td>
                    <td>
                      <span class="badge <%= leave.status === 'Approved' ? 'bg-success' : leave.status === 'Rejected' ? 'bg-danger' : 'bg-warning' %>">
                        <%= leave.status %>
                      </span>
                    </td>
                    <td>
                      <% if(leave.status === 'Pending') { %>
                        <button class="btn btn-sm btn-success approve-btn" 
                                data-id="<%= leave._id %>"
                                title="Approve">
                          <i class="fas fa-check"></i>
                        </button>
                        <button class="btn btn-sm btn-danger ms-1 reject-btn" 
                                data-id="<%= leave._id %>"
                                title="Reject">
                          <i class="fas fa-times"></i>
                        </button>
                      <% } else { %>
                        <span class="text-muted">-</span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="6" class="text-center text-muted">No leave requests found</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Apply Leave Modal -->
<div class="modal fade" id="applyLeaveModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <form action="/leaves/apply" method="POST">
        <div class="modal-header">
          <h5 class="modal-title">Apply for Leave</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label">Select Employee</label>
            <select class="form-select" name="employeeId" required>
              <option value="">Choose an employee...</option>
              <% employees.forEach(emp => { %>
                <option value="<%= emp._id %>"><%= emp.name %> - <%= emp.department %></option>
              <% }) %>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label">Leave Type</label>
            <select class="form-select" name="leaveType" required>
              <option value="Casual Leave">Casual Leave</option>
              <option value="Sick Leave">Sick Leave</option>
              <option value="Annual Leave">Annual Leave</option>
              <option value="Emergency Leave">Emergency Leave</option>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label">Start Date</label>
            <input type="date" class="form-control" name="startDate" required>
          </div>
          <div class="mb-3">
            <label class="form-label">End Date</label>
            <input type="date" class="form-control" name="endDate" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Reason</label>
            <textarea class="form-control" name="reason" rows="3" required></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Submit Request</button>
        </div>
      </form>
    </div>
  </div>
</div>
